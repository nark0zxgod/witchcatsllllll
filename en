  <string name="$Script_EP3_CH2_BQ1_POR1_Npc.0034_1">CHUR! CHURRR!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.0001_2">Oh boy... The Churro Golem\'s really angry now!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.0003_3">Oh, he\'s not afraid of my lollipop this time...!</string>
