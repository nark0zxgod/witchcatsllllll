  <string name="$Item.Deco.cookie0002.TeddyBear">Strawberry Cookie Bear Jelly Toy</string>
  <string name="$Season.2012.Complete.Profile">Completed Buckwheat Collection</string>
  <string name="$Season.2012.Complete.Profile.Story">A memory of completing the Buckwheat Collection! With friends who believe in me, everything will work out fine!</string>
