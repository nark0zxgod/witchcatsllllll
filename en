  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.2004_5">My pliers? Does something need fixin\' right now?!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.0002_6">Erm... No, more like, if we... HYA!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.0025_7">That was your plan?! Just throwing it?</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Npc.0034_8">CH-CHUR?!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.0001_9">OH?! It looks like that worked!</string>
  <string name="$Script_EP3_CH2_BQ1_POR1_Cookie.2004_10">Okay! Let\'s keep throwing\'em to chase him away!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY1_Npc.0034_1">Churr!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY1_Npc.0034_2">CH-CHUR!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY1_Npc.0034_3">CHURRooo!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY1_Cookie.0001_4">I can\'t find any weak spots!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY1_Cookie.2004_5">We need to be quicker!!!</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Npc.0034_1">Churr...</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Cookie.0001_2">Hey! What\'s he doing now???</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Cookie.0002_3">Is he about to run away???</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Npc.0034_4">RRROOOOOO!</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Cookie.0003_5">EEEK! What\'s happening?!</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Cookie.2004_6">CHURRO VINES! The golem\'s trying to tie everything down!</string>
  <string name="$Script_EP3_CH2_BQ1_POR2_Cookie.2004_7">Focus on the vines first! Don\'t give up now!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY2_Npc.0034_1">CHURRRAAAGH!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY2_Npc.0034_2">Chu-rr churr...!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY2_Cookie.2004_3">NOW\'S OUR CHANCE!</string>
  <string name="$Script_EP3_CH2_BQ1_MINI1_Npc.0034_1">Chur CHURRO!</string>
  <string name="$Script_EP3_CH2_BQ1_POR3_Cookie.0001_1">We did it! We won!!!</string>
  <string name="$Script_EP3_CH2_BQ1_POR3_Cookie.0003_2">Look! Rosemary Cookie is sinking in syrup!</string>
  <string name="$Script_EP3_CH2_BQ1_POR3_Cookie.0025_3">We need to make haste! We should fix the Sweet Heart and get her out of there!</string>
  <string name="$Script_EP3_CH2_BQ1_POR3_Cookie.2004_4">Let\'s move these together! We\'ll need these giant pliers to fix the Sweet Heart!</string>
  <string name="$Script_EP3_CH2_BQ1_POR3_Cookie.0001_5">We\'re with you all the way, Radish Cookie!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY3_Cookie.0001_1">The syrup\'s stopped!</string>
  <string name="$Script_EP3_CH2_BQ1_PLAY3_Cookie.2004_2">Let\'s get her outta there!</string>
  <string name="$Script_EP3_CH2_BQ1_CUT_CLEAR_Npc.0037_1">That was a really close call!</string>
