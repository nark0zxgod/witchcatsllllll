  <string name="$Item.Deco.CookieRoom.cookie2016.Ceil.999.Story">Welcome to Melted Choco Cookie\'s Ooey-Gooey Choco Room!</string>
  <string name="$UX.CPC.cookie.2016.Title.Main">Oooey-Gooey Training!</string>
  <string name="$UX.CPC.cookie.2016.Title.01">I\'m Strooonger!</string>
  <string name="$UX.CPC.cookie.2016.Title.02">My Traaaining Regimen!</string>
