  <string name="$item.Deco.CookieRoom.cookie2016.Ceil.002">Oozing Choco Curtains</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Ceil.003">Gooey Ceiling Lamp</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Rug.001">Choco Waffle Rug</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Floor.008">Chocolate Wafer Fence</string>
