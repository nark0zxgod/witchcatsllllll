  <string name="$Item.Deco.Season.cookie0044.Limited.Floor.001">Werewolf Cookie Bear Jelly Toy</string>
  <string name="$Item.Deco.Season.cookie0037.Limited.Floor.001">Cheesecake Cookie Bear Jelly Toy</string>
