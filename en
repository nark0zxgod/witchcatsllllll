  <string name="$EP1.CH01.Profile">Profile obtained by completing the \"One Small, Brave Step\" Chapter</string>
  <string name="$EP1.CH02.Profile">Profile obtained by completing the \"Towards the Window\" Chapter</string>
  <string name="$EP2.CH01.Profile">Profile obtained by completing the \"Happenings at the Hotel\" Chapter</string>
  <string name="$EP2.CH02.Profile">Profile obtained by completing the \"Reclaim the Hotel!\" Chapter</string>
  <string name="$EP2.CH03.Profile">Profile obtained by completing the \"End of a Bad Relationship\" Chapter</string>
  <string name="$EP3.CH01.Profile">Profile obtained by completing the \"Protector of the Dry Garden\" Chapter</string>
