  <string name="$Script_MillionDoors_Meet_CRO_cookie0172_dialogue1">We\'re legends!
Right...?</string>
  <string name="$Script_MillionDoors_Meet_CRO_cookie0172_dialogue2">We\'re super strong!</string>
  <string name="$Script_MillionDoors_Meet_CRO_cookie0172_dialogue3">We can overcome anything!</string>
  <string name="$Script_MillionDoors_Meet_CK_cookie0014_dialogue1">I should get out more often...</string>
  <string name="$Script_MillionDoors_Meet_CK_cookie0014_dialogue2">Oh, my back...
I think it\'s going to rain...</string>
  <string name="$Script_MillionDoors_Meet_CK_cookie0014_dialogue3">Go slowly...!
I can\'t keep up...!</string>
  <string name="$Script_MillionDoors_Meet_CK_cookie0577_dialogue1">The Light is in my dough!</string>
  <string name="$Script_MillionDoors_Meet_CK_cookie0577_dialogue2">I shall raise my sword
