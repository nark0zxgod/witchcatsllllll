  <string name="$item.Deco.CookieRoom.cookie2016.Ceil.001">Choco Topping Berry Mobile</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Wallpaper.001">Choco Wall Tiles</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Deck.001">Gooey Choco Floor</string>
  <string name="$item.Deco.CookieRoom.cookie2016.Floor.006">Ooey-Gooey Training Dummy</string>
